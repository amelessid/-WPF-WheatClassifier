<Window x:Class="WheatClassifier.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WheatClassifier.Wpf.ViewModels"
        Title="Wheat Classifier"
        Height="720"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="32"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#0F172A" Padding="20">
            <StackPanel>
                <TextBlock Text="🌾" FontSize="42" HorizontalAlignment="Center" Margin="0,10,0,10"/>
                <TextBlock Text="Wheat Classifier" Foreground="White" FontSize="22" FontWeight="Bold" TextAlignment="Center"/>
                <TextBlock Text="TP2 - WPF / MVVM" Foreground="#94A3B8" FontSize="13" TextAlignment="Center" Margin="0,5,0,30"/>

                <Border Background="#1E293B" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                    <TextBlock Text="📁 Chargement CSV" Foreground="White" FontWeight="SemiBold" TextAlignment="Center"/>
                </Border>
                <Border Background="#1E293B" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                    <TextBlock Text="🤖 Classification k-NN" Foreground="White" FontWeight="SemiBold" TextAlignment="Center"/>
                </Border>
                <Border Background="#1E293B" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                    <TextBlock Text="💾 EF Core" Foreground="White" FontWeight="SemiBold" TextAlignment="Center"/>
                </Border>
                <Border Background="#1E293B" CornerRadius="12" Padding="12">
                    <TextBlock Text="🌐 API REST" Foreground="White" FontWeight="SemiBold" TextAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center">
                <TextBlock Text="🌾 Wheat Classifier" FontSize="34" FontWeight="Bold" Foreground="#0F172A" TextAlignment="Center"/>
                <TextBlock Text="Classification automatique des grains avec k-NN" Foreground="#64748B" FontSize="15" Margin="0,6,0,0" TextAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,18" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="20" Margin="10" Height="150">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Accuracy"
                       Foreground="#64748B"
                       FontSize="14"
                       TextAlignment="Center"/>

                            <TextBlock Text="{Binding Accuracy, StringFormat={}{0:P2}}"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#2563EB"
                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Background="White" CornerRadius="16" Padding="20" Margin="10" Height="150">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Valeur de K"
                       Foreground="#64748B"
                       FontSize="14"
                       TextAlignment="Center"/>

                            <TextBlock Text="{Binding K}"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#16A34A"
                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="20" Margin="10" Height="150">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Distance"
                       Foreground="#64748B"
                       FontSize="14"
                       TextAlignment="Center"/>

                            <TextBlock Text="{Binding SelectedDistance}"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#7C3AED"
                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="3" Background="White" CornerRadius="16" Padding="15" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Matrice de confusion"
                                   Foreground="#64748B"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"/>
                        <DataGrid ItemsSource="{Binding ConfusionMatrix}"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          Margin="0,8,0,0"
          FontSize="12"
          RowHeight="26"
          HorizontalScrollBarVisibility="Disabled"
          VerticalScrollBarVisibility="Disabled"
          VerticalAlignment="Top"
          CanUserAddRows="False">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Réel \ Prédit" Binding="{Binding ActualClass}" Width="130"/>
                                <DataGridTextColumn Header="Canadian" Binding="{Binding Canadian}" Width="80"/>
                                <DataGridTextColumn Header="Kama" Binding="{Binding Kama}" Width="80"/>
                                <DataGridTextColumn Header="Rosa" Binding="{Binding Rosa}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="White" CornerRadius="18" Padding="16">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F8FAFC" CornerRadius="14" Padding="12" Margin="0,0,0,12">
                        <WrapPanel VerticalAlignment="Center" HorizontalAlignment="Center" ItemHeight="50">
                            <Button Content="📂 Train" Width="120" Background="#2563EB" Command="{Binding LoadTrainCommand}"/>
                            <Button Content="📂 Test" Width="120" Background="#0EA5E9" Command="{Binding LoadTestCommand}"/>

                            <TextBlock Text="K" VerticalAlignment="Center" Margin="18,0,4,0" FontWeight="Bold"/>
                            <TextBox Width="65" Text="{Binding K, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Distance" VerticalAlignment="Center" Margin="18,0,4,0" FontWeight="Bold"/>
                            <ComboBox Width="160" SelectedValue="{Binding SelectedDistance}" SelectedValuePath="Content" SelectedIndex="0">
                                <ComboBoxItem Content="Euclidean"/>
                                <ComboBoxItem Content="Manhattan"/>
                            </ComboBox>

                            <Button Content="▶ Classifier" Width="130" Background="#16A34A" Command="{Binding ClassifyCommand}"/>
                            <Button Content="🌐 API" Width="100" Background="#7C3AED" Command="{Binding LoadApiCommand}"/>
                        </WrapPanel>
                    </Border>

                    <TabControl>
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8D2;" Foreground="#2563EB" FontSize="18"/>
                                    <TextBlock Text=" Train" Margin="6,0,0,0"/>
                                </StackPanel>
                            </TabItem.Header>
                            <DataGrid ItemsSource="{Binding TrainData}" AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Area" Binding="{Binding Area}"/>
                                    <DataGridTextColumn Header="Perimeter" Binding="{Binding Perimeter}"/>
                                    <DataGridTextColumn Header="Compactness" Binding="{Binding Compactness}"/>
                                    <DataGridTextColumn Header="KernelLength" Binding="{Binding KernelLength}"/>
                                    <DataGridTextColumn Header="KernelWidth" Binding="{Binding KernelWidth}"/>
                                    <DataGridTextColumn Header="AsymmetryCoefficient" Binding="{Binding AsymmetryCoefficient}"/>
                                    <DataGridTextColumn Header="KernelGrooveLength" Binding="{Binding KernelGrooveLength}"/>
                                    <DataGridTextColumn Header="Label" Binding="{Binding Label}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D2;" Foreground="#16A34A" FontSize="18"/>
                                    <TextBlock Text=" Test / Résultats" Margin="6,0,0,0"/>
                                </StackPanel>
                            </TabItem.Header>
                            <DataGrid ItemsSource="{Binding TestData}"/>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" Foreground="#F59E0B" FontSize="18"/>
                                    <TextBlock Text=" Historique" Margin="6,0,0,0"/>
                                </StackPanel>
                            </TabItem.Header>
                            <DataGrid ItemsSource="{Binding Experiments}"/>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE774;" Foreground="#7C3AED" FontSize="18"/>
                                    <TextBlock Text=" API REST" Margin="6,0,0,0"/>
                                </StackPanel>
                            </TabItem.Header>
                            <DataGrid ItemsSource="{Binding ApiProducts}"/>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>